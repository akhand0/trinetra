# Trinetra runs in a full local demo mode with no credentials.
NEXT_PUBLIC_TRINETRA_RUNTIME=local

# Trigger.dev durable chat runtime
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# OpenRouter (OpenAI-compatible Chat Completions) used by the Trigger agent
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
TRINETRA_MODEL=moonshotai/kimi-k3

# ClickHouse Cloud (OLAP)
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# ClickHouse MCP (read-only by default)
# Leave CLICKHOUSE_MCP_URL empty to run the official mcp-clickhouse package
# locally over stdio via uvx. Set it to a managed HTTP MCP endpoint in cloud.
CLICKHOUSE_MCP_URL=
CLICKHOUSE_MCP_AUTH_TOKEN=
CLICKHOUSE_MCP_COMMAND=uvx

# ClickStack (HyperDX) MCP — optional second tool surface with higher-level
# log/metric/trace investigation primitives. Wired only when configured; the
# raw ClickHouse MCP above stays the fallback. Set CLICKSTACK_MCP_URL for a
# hosted HTTP server, or CLICKSTACK_MCP_COMMAND (+ CLICKSTACK_MCP_ARGS) to run
# one locally over stdio.
CLICKSTACK_MCP_URL=
CLICKSTACK_MCP_AUTH_TOKEN=
CLICKSTACK_MCP_COMMAND=
CLICKSTACK_MCP_ARGS=

# ClickHouse-managed Postgres (OLTP)
POSTGRES_URL=

# Optional visual-report email delivery (the report still runs without these)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
